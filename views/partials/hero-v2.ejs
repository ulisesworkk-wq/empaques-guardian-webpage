<!-- ============== HERO V2 — Centrado / Atmosférico ============== -->
<section class="hero-v2" id="hero">
  <div class="hv2-gradient"></div>

  <!-- Productos flotantes: izquierda -->
  <div class="hv2-prod hv2-prod--1">
    <div class="hv2-prod-inner">
      <img src="/img/hero-pouch.jpg" alt="Bolsa Personalizada" draggable="false">
    </div>
  </div>
  <div class="hv2-prod hv2-prod--2">
    <div class="hv2-prod-inner">
      <img src="/img/hero-sachet.jpg" alt="Sachet" draggable="false">
    </div>
  </div>

  <!-- Productos flotantes: derecha -->
  <div class="hv2-prod hv2-prod--3">
    <div class="hv2-prod-inner">
      <img src="/img/hero-caja.jpg" alt="Caja de Cartón" draggable="false">
    </div>
  </div>
  <div class="hv2-prod hv2-prod--4">
    <div class="hv2-prod-inner">
      <img src="/img/hero-tubo.jpg" alt="Tubo de Cartón" draggable="false">
    </div>
  </div>

  <!-- Centro: texto -->
  <div class="hv2-center">

    <!-- Chips / eyebrow -->
    <div class="hv2-badges" style="--d:0.1s">
      <span class="hv2-badge">Grado alimenticio</span>
      <span class="hv2-badge-dot"></span>
      <span class="hv2-badge">Certificado</span>
      <span class="hv2-badge-dot"></span>
      <span class="hv2-badge">Hecho en México</span>
    </div>

    <!-- Headline palabra por palabra -->
    <h1 class="hv2-title">
      <span class="hv2-line">
        <span class="hv2-w" style="--d:.35s">Packaging</span>
        <span class="hv2-w" style="--d:.48s">que</span>
      </span>
      <span class="hv2-line">
        <span class="hv2-w" style="--d:.61s">habla</span>
        <span class="hv2-w" style="--d:.74s">por</span>
      </span>
      <span class="hv2-line">
        <span class="hv2-w hv2-w--serif" style="--d:.87s">tu marca.</span>
      </span>
    </h1>

    <p class="hv2-sub" style="--d:1.1s">
      Bolsas, sachets, cajas y tubos diseñados para destacar en anaquel.<br>
      Producción flexible, calidad de exportación.
    </p>

    <div class="hv2-ctas" style="--d:1.3s">
      <a href="#contactar" class="btn-primary-custom">
        <span>Cotizar proyecto</span>
        <i class="bi bi-arrow-right"></i>
      </a>
      <a href="#productos" class="hv2-link-ghost">
        Ver líneas <i class="bi bi-arrow-right"></i>
      </a>
    </div>

    <!-- Stats bar -->
    <div class="hv2-stats" style="--d:1.5s">
      <div class="hv2-stat">
        <span class="hv2-stat-num">4</span>
        <span class="hv2-stat-label">líneas de producto</span>
      </div>
      <div class="hv2-stat-divider"></div>
      <div class="hv2-stat">
        <span class="hv2-stat-num">100%</span>
        <span class="hv2-stat-label">personalizable</span>
      </div>
      <div class="hv2-stat-divider"></div>
      <div class="hv2-stat">
        <span class="hv2-stat-num">15 días</span>
        <span class="hv2-stat-label">tiempo de entrega</span>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>
