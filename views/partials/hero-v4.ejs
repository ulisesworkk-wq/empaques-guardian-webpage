<!-- ============== HERO V4 — Premium Minimal ============== -->
<section class="hero-v4" id="hero">

  <!-- Top bar -->
  <div class="hv4-topbar">
    <span class="hv4-eyebrow">Empaques Guardian</span>
    <span class="hv4-proof">
      <span class="hv4-proof-dot"></span>
      Grado alimenticio · Certificado · México
    </span>
  </div>

  <!-- Headline + sub + CTA -->
  <div class="hv4-main">

    <h1 class="hv4-title">
      <span class="hv4-clip">
        <span class="hv4-clip-inner" style="--d:.28s">Empaques que elevan</span>
      </span>
      <span class="hv4-clip">
        <span class="hv4-clip-inner hv4-serif" style="--d:.44s">tu marca.</span>
      </span>
    </h1>

    <div class="hv4-divider-line"></div>

    <p class="hv4-sub">
      Packaging personalizado, certificado y listo para escalar tu negocio.
    </p>

    <div class="hv4-cta-wrap">
      <a href="#contactar" class="btn-primary-custom">
        <span><%= data.hero.ctaText %></span>
        <i class="bi bi-arrow-right"></i>
      </a>
    </div>

  </div>

  <!-- Franja de productos -->
  <div class="hv4-products">
    <div class="hv4-pcard" style="--d:1.10s">
      <div class="hv4-pcard-img">
        <img src="/img/hero-pouch.jpg" alt="Bolsas Personalizadas" draggable="false">
      </div>
      <span class="hv4-pcard-name">Bolsas Pouch</span>
    </div>
    <div class="hv4-pcard" style="--d:1.24s">
      <div class="hv4-pcard-img">
        <img src="/img/hero-caja.jpg" alt="Cajas de Cartón" draggable="false">
      </div>
      <span class="hv4-pcard-name">Cajas de Cartón</span>
    </div>
    <div class="hv4-pcard" style="--d:1.38s">
      <div class="hv4-pcard-img">
        <img src="/img/hero-sachet.jpg" alt="Sachets" draggable="false">
      </div>
      <span class="hv4-pcard-name">Sachets</span>
    </div>
    <div class="hv4-pcard" style="--d:1.52s">
      <div class="hv4-pcard-img">
        <img src="/img/hero-tubo.jpg" alt="Tubos de Cartón" draggable="false">
      </div>
      <span class="hv4-pcard-name">Tubos de Cartón</span>
    </div>
  </div>

  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>

</section>
