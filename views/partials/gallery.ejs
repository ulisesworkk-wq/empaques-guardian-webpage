<!-- ============== GALERÍA — Ejemplos ============== -->
<section class="gallery-section" id="galeria">

  <!-- Carrusel horizontal -->
  <div class="container-fluid px-4 px-lg-5 mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <h3 class="gallery-title reveal-up">
        Trabajos <span class="serif-italic">realizados</span>
      </h3>
      <div class="gallery-nav d-none d-md-flex gap-2">
        <button class="nav-arrow" id="galleryPrev" aria-label="Anterior"><i class="bi bi-arrow-left"></i></button>
        <button class="nav-arrow" id="galleryNext" aria-label="Siguiente"><i class="bi bi-arrow-right"></i></button>
      </div>
    </div>

    <div class="gallery-track" id="galleryTrack">
      <% data.gallery.forEach(function(g) { %>
        <div class="gallery-item">
          <% if (g.link) { %>
            <a href="<%= g.link %>" class="gallery-img-wrap gallery-img-wrap--linked">
              <img src="/img/<%= g.img %>" alt="<%= g.name %>" loading="lazy">
              <div class="gallery-overlay">
                <span class="gallery-overlay-btn">Ver ejemplos <i class="bi bi-arrow-right"></i></span>
              </div>
            </a>
          <% } else { %>
            <div class="gallery-img-wrap">
              <img src="/img/<%= g.img %>" alt="<%= g.name %>" loading="lazy">
            </div>
          <% } %>
          <span class="gallery-name"><%= g.name %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Bloque de texto grande impactante -->
  <div class="gallery-mask-block">
    <h2 class="gallery-mask-text">
      <span>diseño.</span>
      <span class="serif-italic">calidad.</span>
      <span>entrega.</span>
    </h2>
  </div>

</section>
